<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050505"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/txtTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CYBER FIREWALL"
        android:textColor="#00FFFF"
        android:textSize="28sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/txtStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:background="#101010"
        android:padding="12dp"
        android:text="[SYSTEM READY]"
        android:textColor="#00FFAA"
        android:textSize="16sp" />

    <Button
        android:id="@+id/btnOverlay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="REQUEST OVERLAY"
        android:textColor="#FFFFFF"
        android:backgroundTint="#FF0033"/>

    <Button
        android:id="@+id/btnStartVpn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="START FIREWALL VPN"
        android:textColor="#FFFFFF"
        android:backgroundTint="#00BCD4"/>

    <TextView
        android:id="@+id/txtLogs"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="20dp"
        android:background="#0A0A0A"
        android:padding="12dp"
        android:text="[LOGS]\nWaiting..."
        android:textColor="#00FF66"
        android:textSize="14sp"
        android:fontFamily="monospace"/>

</LinearLayout>
